# Your Looki API base URL and API key — generate both at:
#   https://web.looki.ai/api-keys
LOOKI_BASE_URL=https://your-looki-base-url

# Your Looki API key (starts with lk-)
LOOKI_API_KEY=lk-your-api-key-here

# Port for the MCP server (default: 3456)
LOOKI_PORT=3456

# Optional: Bind address (default: 0.0.0.0). Use 127.0.0.1 when the server runs
# behind a reverse proxy on the *same host* (e.g. Cloudflare Tunnel or Caddy on
# the box) so only localhost can reach the raw server port. Docker/container
# users *must* leave at 0.0.0.0 or the published port won't be reachable from
# outside the container.
LOOKI_BIND_HOST=0.0.0.0

# Optional: Public URL where this server is reachable (used for MCP icon display)
# Example: https://looki-mcp.yourdomain.com
LOOKI_MCP_BASE_URL=

# Optional: Your timezone for "today"/"recent" date calculations.
# Use an IANA name like "America/New_York", "Europe/London", or "Asia/Tokyo".
# When unset, the server uses UTC for date calculations. Tool responses
# always include both _local and _utc dates so the consumer sees both.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
LOOKI_USER_TIMEZONE=

# Optional: Direct TLS (HTTPS) — set both to serve HTTPS without a reverse proxy.
# Leave both unset to serve HTTP (recommended only behind a TLS-terminating
# reverse proxy like Cloudflare Tunnel, Caddy, or nginx).
# See README "TLS / HTTPS" section for setup options including Let's Encrypt.
LOOKI_TLS_CERT_PATH=
LOOKI_TLS_KEY_PATH=

# Optional: Shared secret for additional request authentication
# Add "x-origin-secret: <value>" header in your MCP client configuration
ORIGIN_SHARED_SECRET=

# Optional: Path to the `ffmpeg` binary used by the `extract_video_frames` tool.
# Defaults to `ffmpeg` found on $PATH if unset or empty. Only needed if you
# call extract_video_frames and want to override the binary location.
FFMPEG_BIN=ffmpeg

# Optional: Forge (OpenAI-compatible) endpoint + key for visual descriptions in
# the `describe_realtime_event` tool. When FORGE_URL is set and a snapshot is
# present in the realtime event, the tool will call the VLM to produce a
# one-sentence description of the scene. Useful with a local or remote Forge
# instance that supports vision (e.g. gpt-4.1-mini or equivalent).
# See the "Optional Realtime / Forge Extras" section in README.md.
FORGE_URL=
FORGE_API_KEY=
FORGE_VLM_MODEL=openai/gpt-4.1-mini

# Optional: Langfuse observability for tracing the Forge VLM calls made by
# `describe_realtime_event` (and any future instrumented paths in looki-mcp).
# Set LANGFUSE_ENABLED=true and provide keys (and optional BASE_URL for
# self-hosted Langfuse). Matches the pattern used by other MCPs in the stack.
# Traces are named looki-mcp.realtime.describe .
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
