# Your Looki API base URL and API key — generate both at:
#   https://web.looki.ai/api-keys
LOOKI_BASE_URL=https://your-looki-base-url

# Your Looki API key (starts with lk-)
LOOKI_API_KEY=lk-your-api-key-here

# Port for the MCP server (default: 3456)
LOOKI_PORT=3456

# Optional: Public URL where this server is reachable (used for MCP icon display)
# Example: https://looki-mcp.yourdomain.com
LOOKI_MCP_BASE_URL=

# Optional: Your timezone for "today"/"recent" date calculations.
# Use an IANA name like "America/New_York", "Europe/London", or "Asia/Tokyo".
# When unset, the server uses UTC for date calculations. Tool responses
# always include both _local and _utc dates so the consumer sees both.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
LOOKI_USER_TIMEZONE=

# Optional: Shared secret for additional request authentication
# Add "x-origin-secret: <value>" header in your MCP client configuration
ORIGIN_SHARED_SECRET=
