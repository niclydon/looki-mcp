# Your Looki API base URL (found in Looki app → Settings → Developer)
LOOKI_BASE_URL=https://your-looki-base-url

# Your Looki API key (starts with lk-)
LOOKI_API_KEY=lk-your-api-key-here

# Port for the MCP server (default: 3456)
LOOKI_PORT=3456

# Optional: Public URL where this server is reachable (used for MCP icon display)
# Example: https://looki-mcp.yourdomain.com
LOOKI_MCP_BASE_URL=

# Optional: Shared secret for additional request authentication
# Add "x-origin-secret: <value>" header in your MCP client configuration
ORIGIN_SHARED_SECRET=
